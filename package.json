{
  "name": "@cto.af/eslint-plugin-meta",
  "version": "3.0.0",
  "description": "Ensure eslint all rules are sorted, not deprecated, and included",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "Joe Hildebrand",
  "main": "./lib/index.js",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cto-af/eslint-plugin-meta.git"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "table": "generate-rules-table",
    "lint": "eslint .",
    "test": "c8 mocha tests --recursive",
    "ci": "npm run lint && npm run test"
  },
  "devDependencies": {
    "@cto.af/generate-rules-table": "^1.0.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.1.0",
    "eslint-plugin-eslint-plugin": "^7.3.2",
    "eslint-plugin-mocha": "^11.2.0",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "superc8": "~12.3.1"
  },
  "peerDependencies": {
    "eslint": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "mocha@11.7.5>diff": "8.0.3",
      "mocha@11.7.5>minimatch": "10.2.4",
      "mocha@11.7.5>serialize-javascript": "7.0.4"
    }
  },
  "engines": {
    "node": ">=20"
  }
}

{
  "name": "@cto.af/eslint-plugin-meta",
  "version": "3.0.0",
  "description": "Ensure eslint all rules are sorted, not deprecated, and included",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "Joe Hildebrand",
  "main": "./lib/index.js",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cto-af/eslint-plugin-meta.git"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "table": "generate-rules-table",
    "lint": "eslint .",
    "test": "c8 mocha tests --recursive",
    "ci": "npm run lint && npm run test"
  },
  "devDependencies": {
    "@cto.af/generate-rules-table": "1.0.4",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.9.0",
    "c8": "10.1.3",
    "eslint": "^10.0.1",
    "eslint-plugin-eslint-plugin": "^7.3.1",
    "eslint-plugin-mocha": "11.2.0",
    "globals": "17.3.0",
    "mocha": "^11.7.5"
  },
  "peerDependencies": {
    "eslint": ">=10"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "overrides": {
      "eslint@10.0.1>ajv": "6.14.0",
      "mocha@11.7.5>diff": "8.0.3",
      "mocha@11.7.5>minimatch": "10.2.2",
      "glob@10.5.0>minimatch": "10.2.2",
      "test-exclude@7.0.1>minimatch": "10.2.2"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
